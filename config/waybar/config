{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 6,
    "margin-top": 8,
    "exclusive": true,
    "gtk-layer-shell": true,
    "passthrough": false,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "mpris",
        "cpu",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "tray",
        "custom/hogwarts"
    ],

    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "Ôàá",
            "2": "Ôàí",
            "3": "Ôàó",
            "4": "Ôàú",
            "5": "Ôàñ",
            "6": "ÔàÑ",
            "7": "Ôàª",
            "8": "Ôàº",
            "9": "Ôà¿",
            "10": "Ôà®",
            "default": "ÔÇó",
            "urgent": "!",
            "empty": "Ôêÿ"
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": []
        },
        "on-click": "activate"
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 48,
        "rewrite": {
            "(.*) ÔÇö Mozilla Firefox": "$1",
            "(.*) - Zen Browser": "$1",
            "(.*) - Dolphin": "$1",
            "(.*) ÔÇö kitty": "$1"
        }
    },

    "clock": {
        "format": "<span font='Cinzel 18'>´èÂ</span>  {:%H:%M}",
        "format-alt": "<span font='Cinzel 14'>{:%A ┬À %e %B}</span>\n<span font='EB Garamond 10'>{:%Y}</span>",
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "left",
            "format": {
                "months": "<span color='#ecc24c'><b>{}</b></span>",
                "days": "<b>{}</b>",
                "weeks": "<span color='#aaa'><i>W{}</i></span>",
                "weekdays": "<span color='#e87d3a'><b>{}</b></span>",
                "today": "<span color='#c0392b'><b>{}</b></span>"
            }
        }
    },

    "cpu": {
        "format": "<span font='Material Symbols Sharp 12'>¯░ò</span> {usage}%",
        "tooltip": true,
        "interval": 3
    },

    "memory": {
        "format": "<span font='Material Symbols Sharp 12'>¯ó╣</span> {}%",
        "interval": 5
    },

    "mpris": {
        "format": "<span font='Material Symbols Sharp 12'>{player_icon}</span> {title} ÔÇö {artist}",
        "format-paused": "<span font='Material Symbols Sharp 12'>¯üÖ</span> {title} ÔÇö {artist}",
        "player-icons": { "default": "¯Äí", "firefox": "´ë®", "zen": "´ë®", "spotify": "´å╝" },
        "status-icons": { "paused": "¯üÖ" },
        "ignored-players": [],
        "title-len": 24,
        "artist-len": 18,
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl next",
        "on-click-right": "playerctl previous"
    },

    "pulseaudio": {
        "format": "<span font='Material Symbols Sharp 12'>{icon}</span> {volume}%",
        "format-muted": "<span font='Material Symbols Sharp 12'>¯üÅ</span> muted",
        "format-icons": {
            "headphone": "¯üï",
            "default": ["¯üÄ", "¯üÉ", "¯üÅ"]
        },
        "scroll-step": 3,
        "on-click": "pavucontrol",
        "tooltip-format": "{desc}"
    },

    "network": {
        "format-wifi": "<span font='Material Symbols Sharp 12'>¯öÿ</span> {essid}",
        "format-ethernet": "<span font='Material Symbols Sharp 12'>´é×</span> {ipaddr}",
        "format-disconnected": "<span font='Material Symbols Sharp 12'>¯»Á</span> offline",
        "tooltip-format": "{ifname} ┬À {ipaddr}",
        "max-length": 22
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "<span font='Material Symbols Sharp 12'>{icon}</span> {capacity}%",
        "format-charging": "<span font='Material Symbols Sharp 12'>¯«è</span> {capacity}%",
        "format-icons": ["¯å£", "¯åØ", "¯å×", "¯åƒ", "¯åá", "¯åí", "¯åó", "¯åú", "¯åñ", "¯åÑ", "¯åª"],
        "format-full": "<span font='Material Symbols Sharp 12'>¯åª</span> full"
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    },

    "custom/hogwarts": {
        "exec": "~/.config/hogwarts/scripts/bar-theme.sh",
        "interval": 10,
        "format": "<span font='Cinzel 12'>{}</span>",
        "on-click": "~/.config/hogwarts/scripts/settings-panel.py",
        "tooltip": true
    }
}
